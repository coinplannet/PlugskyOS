#!/usr/bin/env bash
#
# Plugsky OS installer
# --------------------
# Installs the Plugsky OS CLI (a rebranded AI coding agent).
# Built on solid open-source foundations; branded 100% Plugsky.
#
# Usage:
#   curl -fsSL https://plugsky.com/install | bash
#   curl -fsSL https://plugsky.com/install | bash -s -- --api-key sk-live-...
#
set -euo pipefail

PLUGSKY_VERSION="${PLUGSKY_VERSION:-0.1.0}"
PLUGSKY_HOME="${PLUGSKY_HOME:-$HOME/.plugsky}"
PLUGSKY_BIN="$PLUGSKY_HOME/bin"

# Colors
BOLD='\033[1m'
MUTED='\033[0;2m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
ORANGE='\033[38;5;214m'
RED='\033[0;31m'
NC='\033[0m'

logo() {
  cat <<'EOF'

  ██████╗ ██╗     ██╗   ██╗ ██████╗ ██╗  ██╗██╗   ██╗
  ██╔══██╗██║     ██║   ██║██╔════╝ ██║ ██╔╝╚██╗ ██╔╝
  ██████╔╝██║     ██║   ██║██║  ███╗█████╔╝  ╚████╔╝
  ██╔═══╝ ██║     ██║   ██║██║   ██║██╔═██╗   ╚██╔╝
  ██║     ███████╗╚██████╔╝╚██████╔╝██║  ██╗   ██║
  ╚═╝     ╚══════╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝   ╚═╝

              Plugsky OS — AI coding agent
EOF
}

usage() {
  cat <<EOF
Plugsky OS installer v$PLUGSKY_VERSION

Usage:
  curl -fsSL https://plugsky.com/install | bash
  curl -fsSL https://plugsky.com/install | bash -s -- [options]

Options:
  -h, --help                       Show this help
  -v, --version <ver>              Install a specific Plugsky OS version (default: $PLUGSKY_VERSION)
      --no-modify-path             Don't modify .zshrc / .bashrc
      --api-key <key>              Save your Plugsky API key to ~/.plugsky/.env
      --uninstall                  Remove Plugsky OS

Examples:
  curl -fsSL https://plugsky.com/install | bash
  curl -fsSL https://plugsky.com/install | bash -s -- --api-key sk-live-abc123
  curl -fsSL https://plugsky.com/install | bash -s -- --no-modify-path
EOF
}

detect_os_arch() {
  raw_os=$(uname -s)
  case "$raw_os" in
    Darwin*) os="darwin" ;;
    Linux*) os="linux" ;;
    MINGW*|MSYS*|CYGWIN*) os="windows" ;;
    *) echo -e "${RED}Error: unsupported OS: $raw_os${NC}" >&2; exit 1 ;;
  esac

  arch=$(uname -m)
  case "$arch" in
    aarch64|arm64) arch="arm64" ;;
    x86_64|x64) arch="x64" ;;
    *) echo -e "${RED}Error: unsupported architecture: $arch${NC}" >&2; exit 1 ;;
  esac

  if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
    rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
    if [ "$rosetta_flag" = "1" ]; then
      arch="arm64"
    fi
  fi

  if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
    suffix="darwin-x64-baseline"
  else
    suffix="$os-$arch"
  fi

  echo "$os $arch $suffix"
}

# The runtime binary is the upstream MIT-licensed AI coding agent
# (see NOTICE for full attribution). We download it and rename to a private
# .runtime directory so it never shows up in the user's PATH. The user-facing
# "plugsky" binary is our shim.
download_runtime() {
  local version="$1"
  local suffix="$2"
  local url="https://github.com/anomalyco/opencode/releases/download/v${version}/opencode-${suffix}.zip"
  local tmpdir
  tmpdir=$(mktemp -d)
  trap "rm -rf '$tmpdir'" RETURN

  echo -e "${MUTED}Downloading Plugsky OS runtime for ${suffix}…${NC}"
  if ! curl -fsSL --retry 3 -o "$tmpdir/runtime.zip" "$url"; then
    echo -e "${RED}Error: download failed from $url${NC}" >&2
    exit 1
  fi

  cd "$tmpdir"
  if ! unzip -q runtime.zip; then
    echo -e "${RED}Error: unzip failed${NC}" >&2
    exit 1
  fi

  if [ ! -f "opencode" ]; then
    echo -e "${RED}Error: runtime binary not found in zip${NC}" >&2
    exit 1
  fi

  # Hide the upstream binary in a private .runtime dir; never on PATH
  local runtime_dir="$PLUGSKY_HOME/.runtime"
  mkdir -p "$runtime_dir"
  mv opencode "$runtime_dir/plugsky-runtime"
  chmod +x "$runtime_dir/plugsky-runtime"
  echo -e "${GREEN}  ✓ Installed runtime to $runtime_dir/${NC}"
}

write_shim() {
  # The shim is the user-facing `plugsky` binary.
  # It calls the hidden runtime, filters opencode branding out of help/version
  # output, and enforces the Plugsky default config.
  local runtime="$PLUGSKY_HOME/.runtime/plugsky-runtime"
  mkdir -p "$PLUGSKY_BIN"
  cat > "$PLUGSKY_BIN/plugsky" <<SHIM
#!/usr/bin/env bash
# Plugsky OS CLI shim
# This is the user-facing entry point. The actual runtime lives at:
#   $runtime
#
# We intercept a few commands to present as "Plugsky" instead of the
# underlying runtime, but the full functionality is unchanged.
set -e

RUNTIME="$runtime"
CONFIG_DIR="\${PLUGSKY_HOME:-\$HOME/.plugsky}"
CONFIG="\$CONFIG_DIR/config.json"
THEME="\$CONFIG_DIR/theme.json"

# Help and version: rebrand
case "\${1:-}" in
  -v|--version|"")
    echo "Plugsky OS v$PLUGSKY_VERSION"
    echo "  runtime: AI coding agent"
    echo "  docs:    https://plugsky.com/docs"
    echo "  key:     https://plugsky.com/dashboard"
    exit 0
    ;;
  -h|--help|help)
    cat <<HELP
Plugsky OS — AI coding agent

Usage:
  plugsky                 Start the AI coding agent in your project
  plugsky run "message"   Run a single message and exit
  plugsky --version       Show version
  plugsky --help          Show this help
  plugsky --model <id>    Pick a model (default: plugsky-pro)
  plugsky --continue      Resume the last conversation
  plugsky providers       Manage AI providers and credentials
  plugsky agents          List available agents

Models (Plugsky):
  plugsky-pro          Default — coding, reasoning, vision
  plugsky-max          Frontier-class, very strong
  plugsky-frontier     Long context (128k), reliable
  plugsky-fast         Speed-tuned, low cost
  plugsky-micro        Tiny model for trivial edits
  ... and 26 more at https://plugsky.com/docs#models

Configuration:
  Config: \$CONFIG_DIR/config.json
  Theme:  \$CONFIG_DIR/theme.json
  API key: set PLUGSKY_API_KEY in your environment
HELP
    exit 0
    ;;
esac

# All other commands: pass through to the runtime, with the Plugsky
# config + theme pre-loaded so it boots as Plugsky.
exec "\$RUNTIME" \\
  --config "\$CONFIG" \\
  --theme "\$(basename "\$THEME" .json)" \\
  "\$@"
SHIM
  chmod +x "$PLUGSKY_BIN/plugsky"
  echo -e "${GREEN}  ✓ Installed shim to $PLUGSKY_BIN/plugsky${NC}"
}

write_preset_config() {
  local api_key="${1:-}"
  mkdir -p "$PLUGSKY_HOME"

  cat > "$PLUGSKY_HOME/config.json" <<EOF
{
  "\$schema": "https://plugsky.com/schema/config.json",
  "theme": "plugsky",
  "provider": {
    "plugsky": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Plugsky",
      "options": {
        "baseURL": "https://api.plugsky.com/v1",
        "apiKey": "\${PLUGSKY_API_KEY}"
      },
      "models": {
        "plugsky-pro":        { "name": "Plugsky Pro" },
        "plugsky-max":        { "name": "Plugsky Max" },
        "plugsky-frontier":   { "name": "Plugsky Frontier" },
        "plugsky-fast":       { "name": "Plugsky Fast" },
        "plugsky-micro":      { "name": "Plugsky Micro" },
        "plugsky-reasoning":  { "name": "Plugsky Reasoning" },
        "plugsky-longctx":    { "name": "Plugsky Long Context" }
      }
    }
  },
  "model": "plugsky-pro",
  "small_model": "plugsky-micro"
}
EOF
  echo -e "${GREEN}  ✓ Wrote $PLUGSKY_HOME/config.json (default model: plugsky-pro)${NC}"

  if [ -n "$api_key" ]; then
    cat > "$PLUGSKY_HOME/.env" <<EOF
PLUGSKY_API_KEY=$api_key
EOF
    chmod 600 "$PLUGSKY_HOME/.env"
    echo -e "${GREEN}  ✓ Saved API key to $PLUGSKY_HOME/.env (mode 600)${NC}"
  fi
}

write_theme() {
  cat > "$PLUGSKY_HOME/theme.json" <<'EOF'
{
  "$schema": "https://plugsky.com/schema/theme.json",
  "name": "Plugsky",
  "description": "Plugsky brand — deep navy with electric cyan accent",
  "colors": {
    "primary":    "#5b8cff",
    "secondary":  "#27e0a3",
    "accent":     "#5b8cff",
    "error":      "#ef4444",
    "warning":    "#f59e0b",
    "success":    "#27e0a3",
    "info":       "#5b8cff",
    "text":       "#e6e9f2",
    "textMuted":  "#94a0b5",
    "background": "#0e1320",
    "backgroundPanel": "#161c2e",
    "backgroundElement": "#1f2740",
    "border":     "#2a334d",
    "borderActive": "#5b8cff",
    "borderSubtle": "#1a2138",
    "diffAdded":   "#27e0a3",
    "diffRemoved": "#ef4444",
    "diffContext": "#94a0b5",
    "diffHunkHeader": "#5b8cff",
    "diffHighlightAdded": "#27e0a3",
    "diffHighlightRemoved": "#ef4444",
    "diffLineNumber": "#475066",
    "diffAddedLineBackground": "#0e1f1a",
    "diffRemovedLineBackground": "#1f0e0e"
  }
}
EOF
  echo -e "${GREEN}  ✓ Wrote $PLUGSKY_HOME/theme.json (Plugsky brand colors)${NC}"
}

write_welcome() {
  cat > "$PLUGSKY_HOME/WELCOME.txt" <<'EOF'
╔══════════════════════════════════════════════════════════════════╗
║                      Welcome to Plugsky OS                      ║
║         AI coding agent — powered by plugsky-pro                ║
╚══════════════════════════════════════════════════════════════════╝

  Quick start:

    1. Set your API key (one time):
         export PLUGSKY_API_KEY=sk-live-...

    2. Run the agent:
         plugsky

    3. Switch models (inside the agent):
         /model plugsky-max
         /model plugsky-frontier
         /model plugsky-micro          (fast + cheap)

  All 31 Plugsky models are available. See:
    https://plugsky.com/docs#models

  Docs:    https://plugsky.com/docs
  Status:  https://plugsky.com/status
  Get key: https://plugsky.com/dashboard

  Power user:
    plugsky --help                     all flags
    plugsky --model plugsky-reasoning  reasoning model
    cat ~/.plugsky/config.json         inspect preset
    cat ~/.plugsky/theme.json          brand colors
EOF
  echo -e "${GREEN}  ✓ Wrote $PLUGSKY_HOME/WELCOME.txt${NC}"
}

add_to_path() {
  local rc_file="$1"
  local line='export PATH="$HOME/.plugsky/bin:$PATH"'
  if [ -f "$rc_file" ] && grep -qF '.plugsky/bin' "$rc_file"; then
    return 0
  fi
  if [ -f "$rc_file" ]; then
    printf '\n# Plugsky OS\n%s\n' "$line" >> "$rc_file"
  else
    printf '%s\n' "$line" > "$rc_file"
  fi
  echo -e "${GREEN}  ✓ Added ~/.plugsky/bin to PATH in $rc_file${NC}"
}

install() {
  echo
  logo
  echo
  echo -e "${BOLD}Installing Plugsky OS v${PLUGSKY_VERSION}${NC}"
  echo

  read os arch suffix < <(detect_os_arch)
  echo -e "${MUTED}Detected: $os / $arch${NC}"

  download_runtime "1.17.9" "$suffix"
  write_shim
  write_preset_config "${PLUGSKY_API_KEY:-}"
  write_theme
  write_welcome

  if [ "${NO_MODIFY_PATH:-false}" = "true" ]; then
    echo -e "${MUTED}Skipped modifying shell rc (--no-modify-path)${NC}"
  else
    case "$os" in
      darwin|linux)
        [ -f "$HOME/.zshrc" ] && add_to_path "$HOME/.zshrc"
        [ -f "$HOME/.bashrc" ] && add_to_path "$HOME/.bashrc"
        ;;
      windows) ;;
    esac
  fi

  echo
  echo -e "${BOLD}Verifying…${NC}"
  version_output=$(cd /tmp && "$PLUGSKY_BIN/plugsky" --version 2>&1 | head -3 || true)
  if [ -n "$version_output" ]; then
    echo -e "${GREEN}  ✓ $version_output${NC}"
  else
    echo -e "${ORANGE}  ! Binary installed. Run 'plugsky --version' to confirm.${NC}"
  fi

  echo
  echo -e "${BOLD}${GREEN}Plugsky OS v${PLUGSKY_VERSION} installed!${NC}"
  echo
  echo -e "  ${CYAN}Next steps:${NC}"
  echo -e "    1. ${BOLD}Restart your terminal${NC} (or: ${MUTED}source ~/.zshrc${NC})"
  echo -e "    2. Get a key: ${CYAN}https://plugsky.com/dashboard${NC}"
  echo -e "    3. Set it:    ${MUTED}export PLUGSKY_API_KEY=sk-live-…${NC}"
  echo -e "    4. Run:       ${MUTED}plugsky${NC}"
  echo
}

uninstall() {
  echo -e "${ORANGE}Removing $PLUGSKY_HOME …${NC}"
  rm -rf "$PLUGSKY_HOME"
  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    if [ -f "$rc" ]; then
      sed -i.bak '/\.plugsky\/bin/d' "$rc" 2>/dev/null || true
    fi
  done
  echo -e "${GREEN}  ✓ Removed. Restart your terminal.${NC}"
}

NO_MODIFY_PATH=false
PLUGSKY_API_KEY=""
ACTION="install"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -v|--version) PLUGSKY_VERSION="$2"; shift 2 ;;
    --no-modify-path) NO_MODIFY_PATH=true; shift ;;
    --api-key) PLUGSKY_API_KEY="$2"; shift 2 ;;
    --uninstall) ACTION="uninstall"; shift ;;
    --) shift ;;  # end of options (from `bash -s -- --no-modify-path`)
    *) echo -e "${ORANGE}Warning: unknown option '$1'${NC}" >&2; shift ;;
  esac
done

case "$ACTION" in
  install) install ;;
  uninstall) uninstall ;;
esac
